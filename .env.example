TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
TWITTER_POST_HANDLE=

SERPER_API_KEY=
SERPER_ENDPOINT=https://google.serper.dev/search

