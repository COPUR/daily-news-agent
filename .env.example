APP_NAME=Daily News Agent (Node)
APP_HOST=0.0.0.0
APP_PORT=8000
DATABASE_URL=file:./data/ev_news_node.db
LOG_LEVEL=info

USER_AGENT=DailyNewsAgentNode/1.0 (+local-first; contact: local-admin)
REQUEST_TIMEOUT_SECONDS=25
REQUEST_RATE_LIMIT_SECONDS=1.5

DAILY_POST_HOUR_UTC=0
DAILY_POST_MINUTE_UTC=5
DAILY_ITEMS_MIN=3
DAILY_ITEMS_MAX=7
DAILY_ITEMS_DEFAULT=5

LLM_PROVIDER=none
DAILY_POST_LANGUAGE=en
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
HUGGINGFACE_API_KEY=
