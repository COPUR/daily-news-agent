APP_NAME=Daily News Agent (Node)
APP_HOST=0.0.0.0
APP_PORT=8000
DATABASE_URL=file:./data/ev_news_node.db
LOG_LEVEL=info

USER_AGENT=DailyNewsAgentNode/1.0 (+local-first; contact: local-admin)
REQUEST_TIMEOUT_SECONDS=25
REQUEST_RATE_LIMIT_SECONDS=1.5

DAILY_POST_HOUR_UTC=0
DAILY_POST_MINUTE_UTC=5
DAILY_ITEMS_MIN=3
DAILY_ITEMS_MAX=7
DAILY_ITEMS_DEFAULT=5

LLM_PROVIDER=none
DAILY_POST_LANGUAGE=en
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL_ID=ytu-ce-cosmos/Turkish-Llama-8b-Instruct-v0.1
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4-0709

TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
TWITTER_POST_HANDLE=

SERPER_API_KEY=
SERPER_ENDPOINT=https://google.serper.dev/search

KEYCLOAK_ENABLED=false
KEYCLOAK_BASE_URL=http://localhost:8080
KEYCLOAK_REALM=master
KEYCLOAK_CLIENT_ID=daily-news-agent
KEYCLOAK_AUDIENCE=
KEYCLOAK_SCOPE=openid profile email
KEYCLOAK_ISSUER_URL=
KEYCLOAK_CLOCK_SKEW_SECONDS=30
KEYCLOAK_JWKS_CACHE_SECONDS=300
KEYCLOAK_ADMIN_ROLES_CSV=admin,super-admin
KEYCLOAK_OPERATOR_ROLES_CSV=operator,admin,super-admin
KEYCLOAK_EDITOR_ROLES_CSV=editor,operator,admin,super-admin
KEYCLOAK_ANALYST_ROLES_CSV=viewer,analyst,editor,operator,admin,super-admin

INTERNAL_AUTH_ENABLED=false
INTERNAL_AUTH_USERNAME=internal-service
INTERNAL_AUTH_PASSWORD=
INTERNAL_AUTH_PASSWORD_HASH=
INTERNAL_AUTH_JWT_SECRET=
INTERNAL_AUTH_ISSUER=daily-news-agent.internal
INTERNAL_AUTH_AUDIENCE=daily-news-agent.business
INTERNAL_AUTH_TOKEN_TTL_SECONDS=900
INTERNAL_AUTH_ALLOWED_CLOCK_SKEW_SECONDS=30
INTERNAL_AUTH_RATE_LIMIT_WINDOW_SECONDS=60
INTERNAL_AUTH_RATE_LIMIT_MAX_ATTEMPTS=5

NEWSLETTER_NOSQL_PATH=./.runtime/newsletter_documents.json
SUPPORTED_SCRAPE_LANGUAGES_CSV=en,tr,zh,ru,uk,fr,de,es,it,pt,nl,pl,sv,no,fi,da,cs,ro,hu,el,bg,sr,hr,sk,sl,et,lv,lt
